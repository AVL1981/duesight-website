# DueSight Website - Environment Variables
# Copy to .env and fill in runtime-specific values. Never commit real secrets.

# Environment mode
DUESIGHT_ENV=development

# API security
DUESIGHT_AUTH_ENABLED=true
DUESIGHT_API_KEYS=dev_replace_with_random_api_key
DUESIGHT_ADMIN_API_KEYS=dev_replace_with_random_admin_key
DUESIGHT_PUBLIC_RATE_LIMIT_PER_MINUTE=30
DUESIGHT_PROTECTED_RATE_LIMIT_PER_MINUTE=120
DUESIGHT_RATE_WINDOW_SECONDS=60
DUESIGHT_ENABLE_HSTS=false
DUESIGHT_DDINTEL_BASE_URL=http://127.0.0.1:8000
DUESIGHT_ENABLE_LEGACY_CHECKOUT=false

# Official KVK provider path.
# Zoeken API V2 + Basisprofiel API are for identity and registration checks.
# Jaarrekeningen use a separate Dataservice/HVDS/BYOD route, not the regular KVK API.
KVK_API_KEY=replace_with_direct_kvk_api_key
KVK_API_MODE=production
KVK_JAARREKENINGEN_DATASERVICE_ENABLED=false
KVK_JAARREKENINGEN_DATASERVICE_KEY=

# Shadow intelligence. Active scans require explicit target permission.
DUESIGHT_SHADOW_ENABLED=false
DUESIGHT_SHADOW_TIMEOUT_SECONDS=180
DUESIGHT_SHADOW_INTEL_ENABLED=true
DUESIGHT_SHADOW_LIVE_ENABLED=true
DS_GAP_CLOSURE_PATH=./ds-gap-closure
DUESIGHT_SHADOW_MEDIA_DAYS=14
DUESIGHT_SHADOW_CYBER_SURFACE_ENABLED=false
DUESIGHT_SHADOW_AHMIA_ENABLED=false
DUESIGHT_SHADOW_NER_ENABLED=false
DS_GAP_ALLOW_ACTIVE_SCANS=false
DS_GAP_AUTO_DOWNLOAD_MODELS=false

# AI budget guard
DUESIGHT_AI_BUDGET_ENABLED=true
DUESIGHT_AI_DAILY_EUR_LIMIT=10.00
DUESIGHT_AI_PROVIDER_DAILY_EUR_LIMIT=5.00
DUESIGHT_AI_DAILY_CALL_LIMIT=200
DUESIGHT_AI_PROVIDER_DAILY_CALL_LIMIT=80
DUESIGHT_AI_DEFAULT_CALL_EUR=0.02
DUESIGHT_AI_ANTHROPIC_CALL_EUR=0.03
DUESIGHT_ALLOW_LOCAL_AI=false
DUESIGHT_ALLOW_CLI_AUTH=false
DUESIGHT_ALLOW_FREE_FALLBACKS=false
DUESIGHT_OLLAMA_ENABLED=false

# Premium PAYG evidence add-ons.
# Store real values only in a secret store/runtime env.
EXA_API_KEY=<your-exa-api-key>
HANDELSREGISTER_AI_API_KEY=<your-handelsregister-ai-api-key>
HANDELSREGISTER_AI_BEARER_TOKEN=
HANDELSREGISTER_AI_BASE_URL=https://handelsregister.ai/api/v1
DUESIGHT_HANDELSREGISTER_AI_DETAIL_ENABLED=true
DUESIGHT_HANDELSREGISTER_AI_DETAIL_FEATURES=financial_kpi,related_persons,publications,insolvency_publications,shareholders,ubos,shareholdings
DUESIGHT_HANDELSREGISTER_AI_AI_SEARCH=false
DUESIGHT_HANDELSREGISTER_AI_REALTIME=false
FIRMENBUCH_AI_API_KEY=<your-firmenbuch-or-firmenakte-api-key>
FIRMENBUCH_AI_SEARCH_URL=<provider-search-endpoint-url>
FIRMENBUCH_AI_AUTH_HEADER=x-api-key
DUESIGHT_EXA_SEARCH_CALL_EUR=0.007
DUESIGHT_HANDELSREGISTER_AI_SEARCH_CALL_EUR=0.05
DUESIGHT_HANDELSREGISTER_AI_DETAIL_CALL_EUR=0.25
DUESIGHT_HANDELSREGISTER_AI_PERSON_CALL_EUR=0.30
DUESIGHT_HANDELSREGISTER_AI_DOCUMENT_CALL_EUR=0.10
DUESIGHT_FIRMENBUCH_AI_SEARCH_CALL_EUR=0.05

# Switzerland Zefix REST access. Request access via zefix@bj.admin.ch.
ZEFIX_USER=<your-zefix-user>
ZEFIX_PASSWORD=<your-zefix-password>

# BENELUX premium add-ons. NL uses official KVK/DDIntel first; these cover BE/LU gaps.
BELGIUM_COMPANY_API_KEY=<your-belgium-kbo-bce-api-key>
BELGIUM_COMPANY_SEARCH_URL=<provider-search-endpoint-url>
BELGIUM_COMPANY_AUTH_HEADER=Authorization
BELGIUM_COMPANY_API_KEY_AUTH_PREFIX=Bearer
DUESIGHT_BELGIUM_COMPANY_SEARCH_CALL_EUR=0.03
LUXEMBOURG_RCS_API_KEY=<your-luxembourg-rcs-api-key>
LUXEMBOURG_RCS_SEARCH_URL=<provider-search-endpoint-url>
LUXEMBOURG_RCS_AUTH_HEADER=Authorization
LUXEMBOURG_RCS_API_KEY_AUTH_PREFIX=Bearer
DUESIGHT_LUXEMBOURG_RCS_SEARCH_CALL_EUR=0.05

# France SIRENE (INSEE) - free official open data.
FRANCE_SIRENE_API_KEY=<your-insee-sirene-api-key>
FRANCE_SIRENE_SEARCH_URL=<insee-sirene-search-endpoint-url>
FRANCE_SIRENE_AUTH_HEADER=Authorization
FRANCE_SIRENE_API_KEY_AUTH_PREFIX=Bearer
DUESIGHT_FRANCE_SIRENE_SEARCH_CALL_EUR=0.00

# Mollie payment integration
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_PROFILE_ID=pfl_xxxxxxxxxxx
DUESIGHT_BASE_URL=https://duesight.nl
DUESIGHT_LOCAL_PAYMENT_BASE_URL=http://127.0.0.1:5051
DUESIGHT_TERMS_VERSION=tos-2026-05-10-v1.0
DUESIGHT_PRIVACY_VERSION=privacy-2026-05-10-v1.0
DUESIGHT_REQUIRE_TERMS_ACCEPTANCE=true
DUESIGHT_PAYMENT_ADMIN_SECRET=<generate-random-payment-admin-secret>
DUESIGHT_REPORT_RUN_TIMEOUT_SECONDS=1800
DUESIGHT_DELIVERY_WORKER_INTERVAL_SECONDS=60
DUESIGHT_PAYMENT_DATA_DIR=./data
DUESIGHT_PAYMENT_DB_PATH=./data/orders.db
DUESIGHT_SCAN_QUEUE_FILE=./data/scan_queue.jsonl
DUESIGHT_SUPPORT_EVENTS_FILE=./data/support_events.jsonl
DUESIGHT_DELIVERY_EVENTS_FILE=./data/delivery_events.jsonl
DUESIGHT_EMAIL_OUTBOX_FILE=./data/email_outbox.jsonl
DUESIGHT_UPLOAD_DIR=./data/customer_uploads
DUESIGHT_MAX_UPLOAD_BYTES=26214400
DUESIGHT_MAX_UPLOADS_PER_ORDER=5
DUESIGHT_STALE_UPLOAD_RETENTION_HOURS=48

# Email delivery
SMTP_HOST=smtp.hostnet.nl
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=docs@duesight.nl
SMTP_PASS=<your-smtp-password>
SMTP_FROM=docs@duesight.nl
SMTP_FROM_NAME=DueSight Intelligence
DUESIGHT_EMAIL_SEND_ENABLED=false

# Google/Gemini AI
GOOGLE_API_KEY=<your-google-api-key>

# VDR server
VDR_API_KEY=<generate-a-random-32-char-string>
VDR_PORT=5052
